# Fastfile configuration for Ichime TestFlight deployment

default_platform(:tvos)

platform :tvos do
  desc "Upload to TestFlight"
  lane :deploy do |options|
    # Get version from parameters or environment
    version = options[:version] || ENV["VERSION"] || "1.0.0"
    build_number = options[:build_number] || ENV["BUILD_NUMBER"] || "1"

    # Update project configuration
    update_project_version(version: version, build_number: build_number)


    # Build the app
    build_app(
      project: "Ichime.xcodeproj",
      scheme: "Ichime_tvOS",
      destination: "generic/platform=tvOS",
      archive_path: "./build/Ichime.xcarchive",
      export_method: "app-store",
      
      # Переопределяем настройки подписи для архивирования:
      codesigning_identity: "Apple Distribution",
      xcargs: {
        "CODE_SIGN_STYLE" => "Manual",
        "CODE_SIGN_IDENTITY" => "Apple Distribution"
      },
      
      export_options: {
        method: "app-store",
        destination: "upload",
        provisioningProfiles: {
          "dev.midorinome.ichime" => "Ichime Distribution",
          "dev.midorinome.ichime.TopShelf" => "Ichime TopShelf Distribution"
        },
        signingStyle: "manual",
        teamID: "YBBAN7R28K"
      }
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key_path: "~/.appstoreconnect/private_keys/AuthKey_#{ENV['APPLE_API_KEY_ID']}.p8",
      skip_waiting_for_build_processing: true,
      platform: "appletvos", # Указываем платформу tvOS
      distribute_external: true, # Распространять для внешних тестеров
      groups: ["External Testers", "Internal Testers"], # Группы тестирования
      changelog: "Автоматическая сборка версии #{version} (build #{build_number})"
    )

    # Clean up
    clean_build_artifacts
  end

  desc "Test build without uploading"
  lane :test_build do |options|
    version = options[:version] || ENV["VERSION"] || "1.0.0-test"
    build_number = options[:build_number] || ENV["BUILD_NUMBER"] || "1"

    UI.message("🧪 Test build for version #{version} (build #{build_number})")

    # Update project configuration
    update_project_version(version: version, build_number: build_number)


    # Build the app
    build_app(
      project: "Ichime.xcodeproj",
      scheme: "Ichime_tvOS",
      destination: "generic/platform=tvOS",
      archive_path: "./build/Ichime.xcarchive",
      export_method: "app-store",
      skip_package_ipa: false,
      
      # Переопределяем настройки подписи для архивирования:
      codesigning_identity: "Apple Distribution",
      xcargs: {
        "CODE_SIGN_STYLE" => "Manual",
        "CODE_SIGN_IDENTITY" => "Apple Distribution"
      },
      
      export_options: {
        method: "app-store",
        destination: "export",
        provisioningProfiles: {
          "dev.midorinome.ichime" => "Ichime Distribution",
          "dev.midorinome.ichime.TopShelf" => "Ichime TopShelf Distribution"
        },
        signingStyle: "manual",
        teamID: "YBBAN7R28K"
      }
    )

    UI.success("✅ Test build completed successfully!")
    UI.message("IPA saved to: #{lane_context[SharedValues::IPA_OUTPUT_PATH]}")
  end

  # Helper function to update version numbers
  private_lane :update_project_version do |options|
    version = options[:version]
    build_number = options[:build_number]

    UI.message("📝 Updating project version to #{version} (build #{build_number})")
    
    # Update project.yml
    sh("sed -i '' 's/MARKETING_VERSION: \".*\"/MARKETING_VERSION: \"#{version}\"/' ../project.yml")
    sh("sed -i '' 's/CURRENT_PROJECT_VERSION: [0-9]\\+/CURRENT_PROJECT_VERSION: #{build_number}/' ../project.yml")
  end
end
